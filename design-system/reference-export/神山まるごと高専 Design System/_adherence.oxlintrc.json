{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/campaign/**",
              "components/content/**",
              "components/form/**",
              "components/layout/**",
              "components/motion/**",
              "components/navigation/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Jost))/i]",
        "message": "Font not provided by the design system. Available: Jost."
      },
      {
        "selector": "JSXOpeningElement[name.name='ArcPageHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|title|height|key|ref|className|style|children)$/]",
        "message": "<ArcPageHeading> doesn't accept that prop. Declared props: label, title, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='Breadcrumb'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|size|key|ref|className|style|children)$/]",
        "message": "<Breadcrumb> doesn't accept that prop. Declared props: items, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Breadcrumb'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|mobile)$/]",
        "message": "<Breadcrumb> size must be one of 'default' | 'mobile'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:white|black)$/]",
        "message": "<Button> variant must be one of 'white' | 'black'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|mobile)$/]",
        "message": "<Button> size must be one of 'default' | 'mobile'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CampaignLandingPage'] > JSXAttribute > JSXIdentifier[name!=/^(?:scope|title|subtitle|heroImage|whiteLogoSrc|ctaLabel|sections|children|key|ref|className|style|children)$/]",
        "message": "<CampaignLandingPage> doesn't accept that prop. Declared props: scope, title, subtitle, heroImage, whiteLogoSrc, ctaLabel, sections, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CampaignLandingPage'] > JSXAttribute[name.name='scope'] > Literal[value!=/^(?:campaign-tour|campaign-event)$/]",
        "message": "<CampaignLandingPage> scope must be one of 'campaign-tour' | 'campaign-event'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|size|navGroups|key|ref|className|style|children)$/]",
        "message": "<Footer> doesn't accept that prop. Declared props: logoSrc, size, navGroups."
      },
      {
        "selector": "JSXOpeningElement[name.name='Footer'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:default|mobile)$/]",
        "message": "<Footer> size must be one of 'default' | 'mobile'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlobalShell'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|logoSrc|whiteLogoSrc|activeIndex|navItems|forceVariant|key|ref|className|style|children)$/]",
        "message": "<GlobalShell> doesn't accept that prop. Declared props: children, logoSrc, whiteLogoSrc, activeIndex, navItems, forceVariant."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlobalShell'] > JSXAttribute[name.name='forceVariant'] > Literal[value!=/^(?:desktop-left-rail|tablet-mobile-top)$/]",
        "message": "<GlobalShell> forceVariant must be one of 'desktop-left-rail' | 'tablet-mobile-top'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeaderNavigation'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|items|activeIndex|logoSrc|onMenuClick|menuOpen|key|ref|className|style|children)$/]",
        "message": "<HeaderNavigation> doesn't accept that prop. Declared props: variant, items, activeIndex, logoSrc, onMenuClick, menuOpen."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeaderNavigation'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:desktop-left-rail|tablet-mobile-top)$/]",
        "message": "<HeaderNavigation> variant must be one of 'desktop-left-rail' | 'tablet-mobile-top'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HoverMaskLink'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|href|width|aspectRatio|label|onClick|key|ref|className|style|children)$/]",
        "message": "<HoverMaskLink> doesn't accept that prop. Declared props: src, alt, href, width, aspectRatio, label, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='HubSpotFormEmbed'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|height|key|ref|className|style|children)$/]",
        "message": "<HubSpotFormEmbed> doesn't accept that prop. Declared props: variant, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='HubSpotFormEmbed'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:inquiry|mailmagazine)$/]",
        "message": "<HubSpotFormEmbed> variant must be one of 'inquiry' | 'mailmagazine'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LinkCtaCards'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|columns|key|ref|className|style|children)$/]",
        "message": "<LinkCtaCards> doesn't accept that prop. Declared props: items, columns."
      },
      {
        "selector": "JSXOpeningElement[name.name='NewsList'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|key|ref|className|style|children)$/]",
        "message": "<NewsList> doesn't accept that prop. Declared props: items."
      },
      {
        "selector": "JSXOpeningElement[name.name='OverlayNavigation'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|items|onClose|key|ref|className|style|children)$/]",
        "message": "<OverlayNavigation> doesn't accept that prop. Declared props: open, items, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='RevealMotion'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|delay|as|style|key|ref|className|style|children)$/]",
        "message": "<RevealMotion> doesn't accept that prop. Declared props: children, delay, as, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
